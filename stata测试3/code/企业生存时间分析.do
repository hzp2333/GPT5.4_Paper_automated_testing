use "测试企业生存年份.dta" , clear


****************************************************
* 4. 计算相对2010年的变化（%）
****************************************************
bysort 行业门类: egen base2010 = max(cond(成立年份==2010, age, .))
drop if missing(base2010)

gen age_pct = (age - base2010) / base2010 * 100

****************************************************
* 5. 计算"总体均值 + 行业分布"
****************************************************
collapse ///
    (mean) mean_age = age_pct ///
    (p10)  p10 = age_pct ///
    (p90)  p90 = age_pct, ///
    by(成立年份)

****************************************************
* 6. 画图（论文级）
****************************************************
twoway ///
(rarea p10 p90 成立年份, color(gs12)) ///
(line mean_age 成立年份, lcolor(black) lwidth(thick)), ///
yline(0, lpattern(dash) lcolor(gs8)) ///
xtitle("年份") ///
ytitle("存活时长相对变化（%）") ///
title("中国工商注册企业存活时长变化趋势（2010=基期）") ///
legend(order(2 "平均水平" 1 "行业分布（10%-90%）")) ///
xlabel(2010(2)2023) ///
ylabel(-100(10)0, angle(0)) ///
graphregion(color(white)) ///
scheme(s1mono)

